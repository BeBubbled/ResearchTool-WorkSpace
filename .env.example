# Copy this file to .env and fill in your own credentials. Do not commit .env.
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Legacy single preset (shown as "默认 LLM" unless LLM_NAME is set).
LLM_NAME=DeepSeek
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=
LLM_MODEL=

# Optional named presets. List their identifiers in LLM_PRESETS, then set each
# group's display name, OpenAI-compatible base URL, API key, and model ID.
# LLM_PRESETS=deepseek,openai
# LLM_PRESET_DEEPSEEK_NAME=DeepSeek
# LLM_PRESET_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_PRESET_DEEPSEEK_API_KEY=
# LLM_PRESET_DEEPSEEK_MODEL=
# LLM_PRESET_OPENAI_NAME=OpenAI
# LLM_PRESET_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_PRESET_OPENAI_API_KEY=
# LLM_PRESET_OPENAI_MODEL=
